<idea-plugin>
    <id>org.example.stepik</id>
    <name>Stepik Course Editor</name>
    <version>1.0-SNAPSHOT</version>
    <vendor>ai-sec-lab</vendor>
    <description>Edit Stepik courses directly in the IDE with split editor, live preview, and API sync.</description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Stepik"
                  implementationClass="org.example.stepik.StepikFileType"
                  fieldName="INSTANCE"
                  extensions="stepik"/>
        <projectService serviceImplementation="org.example.stepik.service.StepikProjectService"/>
        <fileEditorProvider implementation="org.example.stepik.editor.StepikEditorProvider"/>
        <toolWindow id="Stepik Navigator"
                    anchor="left"
                    factoryClass="org.example.stepik.navigator.StepikToolWindowFactory"/>
        <notificationGroup id="Stepik" displayType="BALLOON"/>
    </extensions>

    <projectListeners>
        <listener class="org.example.stepik.service.StepikSaveListener"
                  topic="com.intellij.openapi.vfs.newvfs.BulkFileListener"/>
    </projectListeners>
</idea-plugin>
